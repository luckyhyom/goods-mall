# 애플리케이션
PORT=4000

# CORS — 허용할 웹 오리진
CORS_ORIGIN=http://localhost:3000

# 데이터베이스
DATABASE_URL="mysql://goods:goods@localhost:3306/goods_mall"

# 인증 (Slice 1) — 시크릿은 실제 값으로 교체할 것
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
REFRESH_TTL_DAYS=3

# Google OAuth (Slice 1 Phase C) — Google Cloud 콘솔에서 발급
GOOGLE_CLIENT_ID=change-me-google-client-id
GOOGLE_CLIENT_SECRET=change-me-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# OAuth 콜백 후 토큰을 전달할 프런트엔드 베이스 URL
WEB_BASE_URL=http://localhost:3000

# 계정 연결용 pending_link JWT 서명 시크릿 (access 시크릿과 분리)
PENDING_LINK_SECRET=change-me-pending-link-secret

# 초기 ADMIN seed (prisma db seed) — 비밀번호는 실제 값으로 교체
ADMIN_EMAIL=admin@goods-mall.local
ADMIN_PASSWORD=change-me-admin-password
